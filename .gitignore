# Build output (see justfile: go build -o bin/audit-log)
/bin/

# Frontend build output (populated by `just web-build`)
/internal/web/dist/*
!/internal/web/dist/.gitkeep

# Node
web/node_modules/

# Test & coverage
*.out
coverage.out
coverage-gate.out
coverage.html
*.coverprofile
profile.cov
cpu.prof
mem.prof

# arch-go (see .dockerignore)
.arch-go

# Local env (tracked: .env.example)
.env
.env.*
!.env.example

# Go
vendor/

# IDE / editor
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Delve debugger
__debug_bin
__debug_bin*

# Optional: live reload / temp
tmp/
air.toml.local

# Git worktrees
.worktrees/
