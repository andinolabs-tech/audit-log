# Runtime Postgres DSN (use audit_log_writer role in production).
AUDIT_LOG_DB_DSN=postgres://audit:audit@localhost:5432/auditlog?sslmode=disable
# Optional: admin/superuser DSN for startup AutoMigrate + bootstrap SQL (role + indexes).
AUDIT_LOG_DB_ADMIN_DSN=postgres://postgres:postgres@localhost:5432/auditlog?sslmode=disable
